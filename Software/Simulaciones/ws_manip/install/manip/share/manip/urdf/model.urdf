<?xml version="1.0"?>
<robot name="arm_3dof">

  <!-- MATERIALS -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>

  <material name="green">
    <color rgba="0 0.8 0 1"/>
  </material>

  <!-- WORLD -->
  <link name="world"/>

  <joint name="fixed_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- BASE -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
      <material name="green"/>
    </visual>
  </link>

  <!-- JOINT 1 -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- LINK 1 -->
  <link name="link_1">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.08"/>
      </geometry>
      <origin xyz="0 0 0.0125"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- JOINT 2 -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.025"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

    <!-- LINK 2 -->
  <link name="link_2">
    <visual>
      <geometry>
        <!-- radius 0.035 → diameter 0.07 -->
        <box size="0.07 0.05 0.18"/>
      </geometry>
      <origin xyz="0 0.01 0.09"/>
      <material name="red"/>
    </visual>
  </link>

  <!-- JOINT 3 -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- LINK 3 -->
  <link name="link_3">
    <visual>
      <geometry>
        <!-- radius 0.035 → diameter 0.07 -->
        <box size="0.05 0.04 0.14"/>
      </geometry>
      <origin xyz="0 0.014 0.07"/>
      <material name="blue"/>
    </visual>
  </link>


  
</robot>
